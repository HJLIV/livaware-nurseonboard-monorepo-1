modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/index.cjs"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
AZURE_AD_TENANT_ID = "9cfee145-5ed6-4c9a-aa8e-0d0365a27984"
AZURE_AD_CLIENT_ID = "e52a64ff-991e-4e28-834e-88e2ad2d54da"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[objectStorage]
defaultBucketID = "replit-objstore-3f20150e-383a-4c65-96ba-981078d9c662"
